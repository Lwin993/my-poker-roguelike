; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="牌打西游"
config/description="扑克 × 西游记 Roguelike — 降妖除魔，爽感拉满"
config/version="1.0.0"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

DeckManager="*res://scripts/core/DeckManager.gd"
HandEvaluator="*res://scripts/core/HandEvaluator.gd"
ScoreCalculator="*res://scripts/core/ScoreCalculator.gd"
ItemManager="*res://scripts/core/ItemManager.gd"
ConfigLoader="*res://scripts/core/ConfigLoader.gd"
RoundManager="*res://scripts/core/RoundManager.gd"
GameState="*res://scripts/core/GameState.gd"
JSBridge="*res://scripts/net/JSBridge.gd"
GameAPI="*res://scripts/net/GameAPI.gd"
GameTheme="*res://scripts/core/GameTheme.gd"
BossSkillManager="*res://scripts/core/BossSkillManager.gd"
MusicManager="*res://scripts/core/MusicManager.gd"

[configuration]

config_version=5

[display]

window/size/viewport_width=480
window/size/viewport_height=854
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/size/minimum_size=Vector2i(360, 640)

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
