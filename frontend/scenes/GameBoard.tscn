[gd_scene load_steps=3 format=3 uid="uid://gameboard"]

[ext_resource type="Script" path="res://scripts/ui/GameBoardUI.gd" id="1"]
[ext_resource type="Script" path="res://scripts/ui/JuiceBackdrop.gd" id="2"]

[node name="GameBoard" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="Backdrop" type="Control" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2
script = ExtResource("2")
variant = "battle"

; ── 随轮次切换的西游主题场景，完整铺满屏幕 ──
[node name="BattleBackground" type="TextureRect" parent="."]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 0.43
modulate = Color(1, 1, 1, 0.96)
expand_mode = 1
stretch_mode = 6
mouse_filter = 2

[node name="BattleVignette" type="ColorRect" parent="."]
layout_mode = 1
anchor_right = 1.0
anchor_bottom = 0.43
color = Color(0.015, 0.018, 0.028, 0.24)
mouse_filter = 2

; ── 装备/法宝是独立中间层，不继承妖怪场景背景 ──
[node name="EquipmentAreaBG" type="ColorRect" parent="."]
layout_mode = 1
anchor_top = 0.43
anchor_right = 1.0
anchor_bottom = 0.56
color = Color(0.055, 0.035, 0.03, 1)
mouse_filter = 2

; ── 手牌与按钮共用独立操作台，和妖怪展示区形成清晰分割 ──
[node name="OperationAreaBG" type="Panel" parent="."]
layout_mode = 1
anchor_top = 0.56
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2

; ── 按战斗草图分区的主画布：上方妖怪/装备，下方道具/手牌 ──
[node name="MainVBox" type="Control" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 9.0
offset_top = 7.0
offset_right = -9.0
offset_bottom = -7.0

; ── 顶部：回合 + 分数 + 出换牌次数 + 金币（横向一排）──
