[gd_scene load_steps=3 format=3 uid="uid://gameboard"]

[ext_resource type="Script" path="res://scripts/ui/GameBoardUI.gd" id="1"]
[ext_resource type="Script" path="res://scripts/ui/JuiceBackdrop.gd" id="2"]

[node name="GameBoard" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="Backdrop" type="Control" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
mouse_filter = 2
script = ExtResource("2")
variant = "battle"

; ── 整体竖向主容器 ──
[node name="MainVBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_left = 7.0
offset_top = 6.0
offset_right = -7.0
offset_bottom = -6.0
theme_override_constants/separation = 5

; ── 顶部：回合 + 分数 + 出换牌次数 + 金币（横向一排）──
[node name="TopBar" type="HBoxContainer" parent="MainVBox"]
